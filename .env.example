# ============================================================
# SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# GROQ AI
# ============================================================
GROQ_API_KEY=
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_WHISPER=whisper-large-v3

# ============================================================
# EMBEDDINGS (Transformers.js)
# ============================================================
TRANSFORMERS_CACHE_DIR=/tmp/transformers-cache

# ============================================================
# RESEND (optional)
# ============================================================
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM_EMAIL=noreply@vevia.ai
RESEND_FROM_NAME=Vevia AI

# ============================================================
# INTERNAL API AUTH (recommended)
# ============================================================
VEVIA_API_TOKEN=

# ============================================================
# VERCEL CRON (optional, recommended on Vercel)
# ============================================================
CRON_SECRET=

# ============================================================
# META WHATSAPP CLOUD API (optional)
# ============================================================
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
